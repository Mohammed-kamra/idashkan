{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@tanstack/react-query": "^5.100.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.10.0",
    "framer-motion": "^12.38.0",
    "i18next": "^21.10.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^11.18.6",
    "react-router-dom": "^7.6.3",
    "react-slick": "^0.30.3",
    "react-virtuoso": "^4.18.4",
    "recharts": "^2.15.0",
    "slick-carousel": "^1.8.1",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "prestart": "node scripts/generateFonts.js && node scripts/write-version.js",
    "start": "vite",
    "prebuild": "node scripts/generateFonts.js && node scripts/write-version.js",
    "build": "cross-env CI=false vite build",
    "build:hostgator": "echo 'Ensure .env.production has VITE_API_BASE_URL and VITE_BACKEND_URL (HTTPS)' && npm run build",
    "test": "echo \"No test runner configured\"",
    "preview": "vite preview",
    "eject": "echo \"Eject is not supported after Vite migration\"",
    "i18n:dedupe": "node scripts/dedupe-i18n-resources.cjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "src/i18n.js"
        ],
        "rules": {
          "no-dupe-keys": "off"
        }
      },
      {
        "files": [
          "src/version.js"
        ],
        "globals": {
          "__APP_VERSION__": "readonly"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
