# Copy to .env (local) or set these in your CI/hosting BEFORE `npm run build`.
# Vite bakes VITE_* into the bundle at build time — not at runtime on the server.
#
# App update banner: bump `frontend/package.json` `version` before each deploy.
# `prebuild` runs `scripts/write-version.js` → `public/version.json` (copied to `build/`).
# Configure your CDN/server so `/version.json` is not cached for a long time (or use short max-age).

# Required for production builds (omit only if the same host serves /api via reverse proxy)
# VITE_USE_PROXY=true   → axios uses /api (same origin; configure nginx/Apache to proxy to Node)
# OR set an absolute API URL:
# VITE_API_BASE_URL=https://your-api.example.com/api

# If unset, the app defaults to http://localhost:5000/api (breaks for real users; images/API fail).

# Backend origin for resolveMediaUrl (no /api suffix)
# VITE_BACKEND_URL=https://your-api.example.com

# Google Sign-In button on /login — must match server GOOGLE_CLIENT_ID (OAuth 2.0 Web client)
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# Optional: always use full-page OAuth (server needs GOOGLE_CLIENT_SECRET) instead of the GIS iframe — e.g. for testing WebView flow in a desktop browser
# VITE_GOOGLE_OAUTH_REDIRECT=true
